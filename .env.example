# Optional: HackerOne API key for your own resolved reports
# Get from: https://hackerone.com/settings/api_token
# Format: "your_username:your_token"
H1_API_KEY=username:token

# Optional: GitHub token for higher rate limits on GitHub writeup repos
# Get from: https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=ghp_...

# Optional: per-skill CLI timeout (seconds). Default: 600
CLI_TIMEOUT_SECONDS=600
